generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  emailVerified          DateTime?
  displayName            String?
  name                   String?
  avatarUrl              String?
  image                  String?
  plan                   Plan                    @default(FREE)
  stripeCustomerId       String?
  language               String                  @default("ja")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  settings               Json                    @default("{}")
  // === オンボーディングフィールド ===
  nickname               String?
  onboardingStep         String? // 'nickname' | 'character_select' | 'first_chat' | 'completed'
  onboardingCompletedAt  DateTime?
  notificationPermission Boolean?
  onboardingCharacterId  String?
  onboardingDeeplinkSlug String?
  bio                    String?
  profilePublic          Boolean                 @default(true)
  coverImageUrl          String?
  locale                 String                  @default("ja")
  accounts               Account[]
  sessions               Session[]
  relationships          Relationship[]
  subscriptions          Subscription[]
  transactions           Transaction[]
  pushSubscriptions      PushSubscription[]
  coinBalance            CoinBalance?
  coinTransactions       CoinTransaction[]
  characterSubscriptions CharacterSubscription[]
  momentComments         MomentComment[]
  commentLikes           CommentLike[]
  letters                Letter[]
  diaryLikes             CharacterDiaryLike[]
  userCards              UserCard[]
  dailyEvents            UserDailyEvent[]
  userStoryProgress      UserStoryProgress[]
  shopOrders             ShopOrder[]
  gachaPities            UserGachaPity[]
  proactiveMessages      CharacterProactiveMessage[]
  limitedScenarioReads   LimitedScenarioRead[]
  storyPollVotes         StoryPollVote[]
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Plan {
  FREE
  STANDARD
  PREMIUM
}

model Character {
  id                      String                  @id @default(uuid())
  name                    String
  nameEn                  String?
  slug                    String                  @unique
  franchise               String
  franchiseEn             String?
  description             String?
  systemPrompt            String                  @db.Text
  voiceModelId            String?
  fcMonthlyCoins          Int                     @default(500) // FC月額コイン（キャラ別）
  chatCoinPerMessage      Int                     @default(10) // チャット1回のコイン消費（キャラ別）
  loginBonusCoins         Int                     @default(50) // ログインボーナス付与コイン
  live2dModelId           String?
  loraModelId             String?
  ragCollectionId         String?
  catchphrases            String[]
  personalityTraits       Json                    @default("[]")
  avatarUrl               String?
  coverUrl                String?
  isActive                Boolean                 @default(true)
  // === 課金設定 ===
  fcMonthlyPriceJpy       Int                     @default(3480) // FC月額（円）最低3480
  fcIncludedCallMin       Int                     @default(30) // FC込み通話時間（分/月）
  callCoinPerMin          Int                     @default(200) // 非FC通話料金（コイン/分）最低200
  fcOverageCallCoinPerMin Int                     @default(100) // FC超過通話料金（コイン/分）最低100
  freeMessageLimit        Int                     @default(10) // 無料チャット上限（通数）
  freeCallMinutes         Int                     @default(5) // 無料通話上限（分）
  stripeProductId         String? // Stripe Product ID
  fcSubscriberCount       Int                     @default(0) // FC加入者数キャッシュ
  onboardingGreetings     Json?                   @default("[]") // オンボーディング第一声（3パターン）
  // === 多言語・地域対応 ===
  // localeConfig: { "en": { voiceModelId, systemPrompt, catchphrases[], toneNotes }, "ko": {...} }
  localeConfig            Json?                   @default("{}") // 言語別の声優/口調/プロンプト設定
  birthday                String? // "MM-DD" format e.g. "05-05" for May 5th
  presenceStatus          String? // 手動上書きステータス（nullなら自動）
  presenceEmoji           String? // 手動上書き絵文字
  presenceManualMode      Boolean                 @default(false) // trueなら手動モード
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  relationships           Relationship[]
  moments                 Moment[]
  momentComments          MomentComment[]
  characterSubscriptions  CharacterSubscription[]
  letters                 Letter[]
  gachaCards              GachaCard[]
  storyChapters           StoryChapter[]
  userStoryProgress       UserStoryProgress[]
  secretContents          SecretContent[]
  downloadableContents    DownloadableContent[]
  shopItems               ShopItem[]
  dailyStates             CharacterDailyState[]
  proactiveMessages       CharacterProactiveMessage[]
  diaries                 CharacterDiary[]
  limitedScenarios        LimitedScenario[]
  storyPolls              StoryPoll[]
}

model SecretContent {
  id             String    @id @default(uuid())
  characterId    String
  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  unlockLevel    Int       @default(3)
  type           String    @default("conversation_topic")
  title          String
  content        String
  promptAddition String?
  order          Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Relationship {
  id                   String         @id @default(uuid())
  userId               String
  characterId          String
  level                Int            @default(1)
  experiencePoints     Int            @default(0)
  totalMessages        Int            @default(0)
  firstMessageAt       DateTime?
  lastMessageAt        DateTime?
  memorySummary        Json           @default("{}")
  milestones           Json           @default("[]")
  isFollowing          Boolean        @default(false)
  isFanclub            Boolean        @default(false)
  characterEmotion     String         @default("neutral")
  characterEmotionNote String?
  emotionUpdatedAt     DateTime?
  streakDays           Int            @default(0)
  streakLastDate       DateTime?
  pendingCliffhanger   Json?
  locale               String         @default("ja")
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  user                 User           @relation(fields: [userId], references: [id])
  character            Character      @relation(fields: [characterId], references: [id])
  conversations        Conversation[]
  letters              Letter[]

  @@unique([userId, characterId, locale])
  @@index([userId, locale])
}

model Conversation {
  id             String       @id @default(uuid())
  relationshipId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  metadata       Json         @default("{}")
  relationship   Relationship @relation(fields: [relationshipId], references: [id])
  messages       Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String       @db.Text
  audioUrl       String?
  imageUrl       String?
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

enum MessageRole {
  USER
  CHARACTER
  SYSTEM
}

model Moment {
  id            String          @id @default(uuid())
  characterId   String
  locale        String?
  type          MomentType
  content       String?         @db.Text
  mediaUrl      String?
  visibility    Visibility      @default(PUBLIC)
  levelRequired Int             @default(0)
  scheduledAt   DateTime?
  publishedAt   DateTime?
  createdAt     DateTime        @default(now())
  character     Character       @relation(fields: [characterId], references: [id])
  reactions     Reaction[]
  comments      MomentComment[]

  @@index([characterId, locale])
}

enum MomentType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
}

enum Visibility {
  PUBLIC
  STANDARD
  PREMIUM
  LEVEL_LOCKED
}

model Reaction {
  id        String   @id @default(uuid())
  momentId  String
  userId    String
  type      String   @default("like")
  createdAt DateTime @default(now())
  moment    Moment   @relation(fields: [momentId], references: [id])

  @@unique([momentId, userId, type])
}

model MomentComment {
  id              String          @id @default(uuid())
  momentId        String
  userId          String?
  characterId     String?
  content         String          @db.Text
  parentCommentId String?
  createdAt       DateTime        @default(now())
  moment          Moment          @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user            User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  character       Character?      @relation(fields: [characterId], references: [id])
  likes           CommentLike[]
  parentComment   MomentComment?  @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies         MomentComment[] @relation("CommentReplies")
}

model CommentLike {
  id        String        @id @default(uuid())
  commentId String
  userId    String
  createdAt DateTime      @default(now())
  comment   MomentComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String
  plan                 Plan
  stripeSubscriptionId String?   @unique
  status               SubStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  canceledAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id])
}

enum SubStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

model Transaction {
  id                    String   @id @default(uuid())
  userId                String
  characterId           String?
  type                  TxType
  amount                Int
  currency              String   @default("jpy")
  stripePaymentIntentId String?
  metadata              Json     @default("{}")
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id])
}

enum TxType {
  TIP
  PPV
  GIFT
  CALL_EXTRA
}

model VerificationCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model CoinBalance {
  id          String   @id @default(uuid())
  userId      String   @unique
  balance     Int      @default(0) // 後方互換用（freeBalance + paidBalanceの合算）
  freeBalance Int      @default(0) // 無料コイン（ログボ等、消費優先）
  paidBalance Int      @default(0) // 購入コイン（Stripe決済）
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoinTransaction {
  id           String     @id @default(uuid())
  userId       String
  type         CoinTxType
  amount       Int
  balanceAfter Int
  characterId  String?
  refId        String?
  description  String?
  metadata     Json       @default("{}")
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([refId])
}

enum CoinTxType {
  PURCHASE
  CALL_OVERAGE
  CHAT_EXTRA
  GIFT_SENT
  GIFT_RECEIVED
  ITEM_PURCHASE
  REFUND
  BONUS
  ADMIN_ADJUST
  LOGIN_BONUS
  SPEND
}

model CharacterSubscription {
  id                   String          @id @default(uuid())
  userId               String
  characterId          String
  stripeSubscriptionId String?         @unique
  status               SubStatus       @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  pricePaidJpy         Int
  callMinutesRemaining Int             @default(0)
  callMinutesTotal     Int             @default(0)
  platform             PaymentPlatform @default(WEB)
  canceledAt           DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  user                 User            @relation(fields: [userId], references: [id])
  character            Character       @relation(fields: [characterId], references: [id])

  @@unique([userId, characterId, status])
  @@index([userId])
  @@index([characterId])
}

enum PaymentPlatform {
  WEB
  IOS
  ANDROID
}

model CoinPackage {
  id            String   @id @default(uuid())
  name          String
  coinAmount    Int
  priceWebJpy   Int
  priceStoreJpy Int
  stripePriceId String?
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Letter {
  id             String       @id @default(cuid())
  relationshipId String
  relationship   Relationship @relation(fields: [relationshipId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  characterId    String
  character      Character    @relation(fields: [characterId], references: [id])
  monthKey       String
  content        String       @db.Text
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@unique([relationshipId, monthKey])
  @@index([userId])
  @@index([characterId])
}

// ========== ガチャシステム ==========

enum GachaRarity {
  N
  R
  SR
  SSR
  UR
}

model GachaCard {
  id              String      @id @default(uuid())
  characterId     String
  name            String
  description     String?     @db.Text
  imageUrl        String?
  voiceUrl        String?
  rarity          GachaRarity
  category        String      @default("memory") // memory | costume | scene
  effect          Json        @default("{}") // { type: "background"|"voice"|"episode", data: ... }
  franchise       String? // アニメ名
  cardImageUrl    String? // カード表面画像
  illustrationUrl String? // フルイラスト画像
  frameType       String?     @default("standard") // standard/gold/rainbow
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  character       Character   @relation(fields: [characterId], references: [id])
  userCards       UserCard[]

  @@index([characterId])
  @@index([rarity])
}

model UserCard {
  id         String    @id @default(uuid())
  userId     String
  cardId     String
  obtainedAt DateTime  @default(now())
  source     String    @default("gacha") // gacha | login_bonus | event | milestone
  user       User      @relation(fields: [userId], references: [id])
  card       GachaCard @relation(fields: [cardId], references: [id])

  @@unique([userId, cardId])
  @@index([userId])
}

model GachaBanner {
  id             String           @id @default(uuid())
  name           String
  description    String?
  characterId    String? // null = 全キャラ混合
  rateUp         Json             @default("{}") // { cardId: multiplier }
  costCoins      Int              @default(100)
  cost10Coins    Int? // 10連コスト（省略時はcostCoins×10）
  guaranteedSrAt Int? // SR確定天井（省略時はnull=天井なし）
  ceilingCount   Int              @default(100) // UR天井（この回数でUR確定）
  franchise      String? // アニメ名（ONE PIECE / 鬼滅の刃 / 呪術廻戦）
  bannerImageUrl String? // バナー画像URL
  themeColor     String? // テーマカラー (#f97316等)
  animationType  String? // 演出タイプ (standard/fire/flame/cursed/golden)
  preRollConfig  Json? // 事前演出設定
  startAt        DateTime
  endAt          DateTime
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  userPities     UserGachaPity[]

  @@index([isActive])
}

model UserGachaPity {
  id        String      @id @default(uuid())
  userId    String
  bannerId  String
  pullCount Int         @default(0)
  user      User        @relation(fields: [userId], references: [id])
  banner    GachaBanner @relation(fields: [bannerId], references: [id])
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([userId, bannerId])
}

model UserDailyEvent {
  id        String   @id @default(uuid())
  userId    String
  date      String // "YYYY-MM-DD"
  eventType String // "normal" | "good" | "rare" | "super_rare"
  reward    Json     @default("{}")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId])
}

// ========== ストーリーモード ==========
model StoryChapter {
  id              String              @id @default(cuid())
  characterId     String
  character       Character           @relation(fields: [characterId], references: [id])
  chapterNumber   Int
  locale          String              @default("ja")
  title           String
  synopsis        String              @db.Text
  unlockLevel     Int                 @default(1)
  isFcOnly        Boolean             @default(false)
  triggerPrompt   String              @db.Text
  choices         Json? // [{ text, consequence, nextTease, xpReward? }]
  isActive        Boolean             @default(true)
  backgroundUrl   String?             // シーン背景画像URL
  bgmType         String?             // 'daily' | 'tension' | 'emotion' | null
  coinReward      Int                 @default(5) // チャプター完了時のコイン報酬
  characterPose   String?             // キャラ立ち絵ポーズ ('normal'|'happy'|'angry'|'sad')
  createdAt       DateTime            @default(now())
  userProgress    UserStoryProgress[]

  @@unique([characterId, chapterNumber])
  @@index([characterId])
}

model DownloadableContent {
  id            String    @id @default(cuid())
  characterId   String
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  type          String    // wallpaper, voice_clip, special_art, etc.
  fileUrl       String    // /uploads/content/{id}.{ext}
  thumbnailUrl  String?
  fcOnly        Boolean   @default(true)
  downloadCount Int       @default(0)
  createdAt     DateTime  @default(now())

  @@index([characterId])
}

model UserStoryProgress {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  characterId String
  character   Character    @relation(fields: [characterId], references: [id])
  chapterId   String
  chapter     StoryChapter @relation(fields: [chapterId], references: [id])
  choicesMade Json         @default("[]")
  isCompleted Boolean      @default(false)
  startedAt   DateTime     @default(now())
  completedAt DateTime?

  @@unique([userId, chapterId])
  @@index([userId, characterId])
}

// ========== ショップ（EC） ==========
model ShopItem {
  id          String      @id @default(cuid())
  characterId String
  character   Character   @relation(fields: [characterId], references: [id])
  name        String
  description String?
  type        String      // digital_wallpaper, digital_voice, physical_goods, etc.
  priceCoins  Int         // コイン価格
  priceJpy    Int?        // 円価格（物理グッズ用、Stripe経由）
  imageUrl    String?
  fileUrl     String?     // デジタル商品のDL URL
  stock       Int?        // 物理グッズの在庫数（nullなら無限）
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  orders      ShopOrder[]

  @@index([characterId])
  @@index([isActive])
}

model ShopOrder {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  itemId          String
  item            ShopItem @relation(fields: [itemId], references: [id])
  quantity        Int      @default(1)
  totalCoins      Int?
  totalJpy        Int?
  status          String   @default("completed") // completed, shipped, cancelled
  shippingAddress String?  // 物理グッズ用
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([itemId])
}

// ========== キャラ主導メッセージ ==========
model CharacterProactiveMessage {
  id          String    @id @default(cuid())
  characterId String
  userId      String
  content     String    @db.Text
  trigger     String    @default("scheduled")
  expiresAt   DateTime
  isRead      Boolean   @default(false)
  readAt      DateTime?
  isExpired   Boolean   @default(false)
  locale      String    @default("ja")
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now())

  character   Character @relation(fields: [characterId], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, isExpired])
  @@index([characterId, userId])
  @@index([expiresAt])
}

// ========== 感情状態システム ==========
model CharacterDailyState {
  id                String    @id @default(uuid())
  characterId       String
  date              DateTime  @db.Date
  emotion           String    // happy / excited / mysterious / tired / nostalgic / playful
  moodScore         Int?      // 1-10 mood intensity
  context           String?
  bonusXpMultiplier Float     @default(1.0)
  innerThoughts     String?   // 今考えていること (AI generated)
  dailyActivity     String?   // 今日やっていたこと (AI generated)
  currentConcern    String?   // 最近気になっていること (AI generated)
  createdAt         DateTime  @default(now())
  character         Character @relation(fields: [characterId], references: [id])

  @@unique([characterId, date])
}



// ========== キャラ感情日記タイムライン ==========
model CharacterDiary {
  id          String   @id @default(uuid())
  characterId String
  date        String   // "YYYY-MM-DD"
  content     String   @db.Text
  mood        String   // happy, sad, excited, tired, neutral 等
  imageUrl    String?
  likes       Int      @default(0)
  createdAt   DateTime @default(now())
  character   Character @relation(fields: [characterId], references: [id])
  diaryLikes  CharacterDiaryLike[]

  @@unique([characterId, date])
  @@index([characterId])
}

model CharacterDiaryLike {
  id        String   @id @default(uuid())
  userId    String
  diaryId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  diary     CharacterDiary @relation(fields: [diaryId], references: [id], onDelete: Cascade)

  @@unique([userId, diaryId])
  @@index([diaryId])
}

// ========== 期間限定絆シナリオ（FOMO演出） ==========
model LimitedScenario {
  id          String    @id @default(uuid())
  characterId String
  title       String
  description String?
  content     String    @db.Text
  startsAt    DateTime
  endsAt      DateTime
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  character   Character @relation(fields: [characterId], references: [id])
  readers     LimitedScenarioRead[]

  @@index([characterId])
  @@index([startsAt, endsAt])
}

model LimitedScenarioRead {
  id         String          @id @default(uuid())
  userId     String
  scenarioId String
  readAt     DateTime        @default(now())
  user       User            @relation(fields: [userId], references: [id])
  scenario   LimitedScenario @relation(fields: [scenarioId], references: [id])

  @@unique([userId, scenarioId])
}

// ========== ユーザー投票型ストーリー ==========
model StoryPoll {
  id             String         @id @default(uuid())
  characterId    String
  title          String
  description    String?        @db.Text
  choices        Json           // [{id: "a", text: "冒険に出る"}, {id: "b", text: "町で修行する"}]
  startsAt       DateTime
  endsAt         DateTime
  isActive       Boolean        @default(true)
  resultChoiceId String?        // 投票結果の選択肢ID
  createdAt      DateTime       @default(now())
  character      Character      @relation(fields: [characterId], references: [id])
  votes          StoryPollVote[]

  @@index([characterId])
  @@index([startsAt, endsAt])
}

model StoryPollVote {
  id       String    @id @default(uuid())
  userId   String
  pollId   String
  choiceId String
  votedAt  DateTime  @default(now())
  user     User      @relation(fields: [userId], references: [id])
  poll     StoryPoll @relation(fields: [pollId], references: [id])

  @@unique([userId, pollId])
}
